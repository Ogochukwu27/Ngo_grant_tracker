# Dependency directories
node_modules/
**/node_modules/

# Production build directories
dist/
**/dist/

# Env files (contains sensitive database URLs, JWT keys, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*

# Backend Uploads (ignore uploaded beneficiary/grant files, but keep the directory)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
